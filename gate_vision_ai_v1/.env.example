# gate_vision_ai_v1 configuration — copy to .env and edit
# All variables use the GV1_ prefix
# All captured_at timestamps sent to the backend are UTC (Z suffix). No TZ config.

GV1_PORT=8001
GV1_CAMERA_URL=0                        # 0 = default webcam, or rtsp://...
GV1_MODEL_PACK=buffalo_s                # buffalo_s (faster) or buffalo_l (more accurate)
GV1_RECOGNITION_THRESHOLD=0.45         # cosine similarity threshold (0–1)

GV1_PROCESSING_FPS=15                  # detection loop frequency
GV1_DETECT_MAX_WIDTH=640               # downscale frames to this width before detection
GV1_MOTION_THRESHOLD=0.02              # skip detection if < 2% of pixels changed
GV1_MOTION_PIXEL_THRESHOLD=25

GV1_MIN_FACE_SIZE=40                   # minimum face bounding box size in pixels
GV1_MIN_FACE_CONFIDENCE=0.5
GV1_MAX_YAW=30                         # degrees
GV1_MAX_PITCH=30
GV1_MIN_SHARPNESS_SCORE=60.0
GV1_MIN_BRIGHTNESS=30
GV1_MAX_BRIGHTNESS=220

GV1_MIN_TRACK_HITS=2                   # frames before a track is confirmed
GV1_TRACKER_MAX_LOST_S=3.0

GV1_FAISS_THRESHOLD=5000               # use FAISS when gallery >= this size
GV1_ENROLL_DEDUP_THRESHOLD=0.95

GV1_FORCE_CPU=false                    # true = skip GPU providers
GV1_LOG_LEVEL=INFO
GV1_CORS_ORIGINS=http://localhost:3000
GV1_LOCAL_API_KEY=                     # set to require X-Api-Key on mutating routes

# Gate identity — needed to fetch per-gate config from the .NET API at startup
# If set, camera_source / processing_fps / thresholds are pulled from the gates table
# and override the defaults above (but are still overridden by GV1_* env vars).
GV1_GATE_ID=                           # UUID of this gate in the gates table
GV1_NET_BACKEND_URL=http://localhost:5000
GV1_NET_API_KEY=                       # X-API-Key for the .NET backend
GV1_LOG_UNKNOWN=false                  # true = also fire events for unrecognised faces
GV1_TRAINING_MODE=false                # true = backend stores unknowns as training data

# Qdrant — enrolled face embeddings are loaded from here at startup
GV1_QDRANT_URL=http://localhost:6333
GV1_QDRANT_COLLECTION=face_embeddings

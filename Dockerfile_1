FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgomp1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml .

# Install CPU onnxruntime; onnxruntime-gpu in pyproject.toml requires CUDA drivers
# which are not present in this slim base image.
RUN pip install --no-cache-dir \
        "fastapi>=0.115.0" \
        "uvicorn>=0.30.0" \
        "opencv-python-headless>=4.9.0" \
        "insightface>=0.7.3" \
        "onnxruntime-gpu>=1.18.0" \
        "httpx>=0.27.0" \
        "pydantic-settings>=2.3.0" \
        "numpy>=1.26.0" && \
    pip install --no-cache-dir --no-deps -e .

COPY . .

ENV GV_GATE_ID=default
ENV GV_NET_BACKEND_URL=http://localhost:5000
ENV GV_NET_API_KEY=change-me-to-your-api-key
ENV GV_CAMERA_SOURCE=0
ENV GV_DIRECTION=entry
ENV GV_LOCAL_BUFFER_PATH=/data/gate_events_local.db

EXPOSE 8000

CMD ["python", "-m", "gate_vision_ai"]

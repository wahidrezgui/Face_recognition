# GateVision AI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env files to source control.

# Camera source: USB device index (0), RTSP URL, or file path
GV_CAMERA_SOURCE=0

# Region of Interest (ROI): detection area within the frame
# Set all to 0 (default) for full-frame detection.
# GV_ROI_X=200
# GV_ROI_Y=100
# GV_ROI_WIDTH=400
# GV_ROI_HEIGHT=300

# .NET backend URL
GV_NET_BACKEND_URL=http://localhost:5000

# API key for authenticating to .NET backend (must match Auth:ApiKey in .NET config)
GV_NET_API_KEY=change-me-to-your-api-key

# Log level: DEBUG, INFO, WARNING, ERROR
GV_LOG_LEVEL=INFO

# Hikvision ISAPI event listener — leave blank to disable (falls back to software motion gate)
# GV_HIKVISION_URL=http://192.168.1.64
# GV_HIKVISION_USER=admin
# GV_HIKVISION_PASSWORD=your-camera-password
# GV_HIKVISION_EVENT_TTL_MS=5000
# GV_HIKVISION_EVENT_TYPES=regionEntrance        # or VMD,fielddetection,linedetection
# GV_HIKVISION_DETECTION_TARGET=human            # empty = any target; "human" = human-only

 
  
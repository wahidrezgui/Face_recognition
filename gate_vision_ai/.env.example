# GateVision AI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env files to source control.

# Unique ID for this gate (must match the Gate.Id in the .NET database)
GV_GATE_ID=default

# Port the FastAPI service listens on
GV_PORT=8000

# Camera source: USB device index (0), RTSP URL, or file path
GV_CAMERA_SOURCE=0

# Region of Interest (ROI): detection area within the frame
# Set all to 0 (default) for full-frame detection.
# GV_ROI_X=200
# GV_ROI_Y=100
# GV_ROI_WIDTH=400
# GV_ROI_HEIGHT=300

# .NET backend URL
GV_NET_BACKEND_URL=http://localhost:5000

# API key for authenticating OUTBOUND requests from Python to .NET backend
# Must match Auth:ApiKey in appsettings.json
GV_NET_API_KEY=change-me-to-your-api-key

# API key required on INBOUND management requests to this Python service
# Leave blank to disable auth (backward-compatible default)
# When set, callers (including .NET) must send X-API-Key: <value> on mutating endpoints
# GV_LOCAL_API_KEY=your-secret-key-here

# Log level: DEBUG, INFO, WARNING, ERROR
GV_LOG_LEVEL=INFO

# Dashboard CORS origins — comma-separated list of allowed origins.
# Override when the dashboard is served from a non-localhost address.
# GV_CORS_ORIGINS=http://localhost:3000,http://192.168.1.10:3000

# SORT tracker: seconds a lost face track is kept alive before being discarded.
# Tight doorway (person in frame ~0.5–1s): use 1.0–1.5.  Wide corridor: use 3.0–5.0.
# GV_TRACKER_MAX_LOST_S=3.0

# Hikvision ISAPI event listener — leave blank (or omit) to use software motion gate instead
# GV_HIKVISION_URL=http://192.168.1.64
# GV_HIKVISION_USER=admin
# GV_HIKVISION_PASSWORD=your-camera-password
# GV_HIKVISION_EVENT_TTL_MS=5000
# GV_HIKVISION_EVENT_TYPES=regionEntrance        # or VMD,fielddetection,linedetection
# GV_HIKVISION_DETECTION_TARGET=human            # empty = any target; "human" = human-only
